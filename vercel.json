{
  "rewrites": [
    {
      "source": "/_next/:path*",
      "destination": "/dashboard/_next/:path*"
    },
    {
      "source": "/simulation/:path*",
      "destination": "/simulation-app/:path*"
    },
    {
      "source": "/(api/.*)",
      "destination": "/dashboard/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/dashboard/$1"
    }
  ]
}
